# ─────────────────────────────────────────────────────────────────────────────
# Fauran waitlist site — environment variables
# Copy this file to `.env` and fill in your Firebase Web app config.
#
# These PUBLIC_ vars are exposed to the browser by Astro (the waitlist write is
# client-side). That is expected and safe for Firebase: the Web API key is not a
# secret — access is controlled by the create-only Firestore security rules in
# `firestore.rules`, NOT by hiding the key.
#
# Create a NEW / dedicated Firebase project for this marketing site, OR reuse an
# existing project but ONLY the dedicated `waitlist_signups` collection. Never
# point this at collections used by the Fauran app.
# ─────────────────────────────────────────────────────────────────────────────

PUBLIC_FIREBASE_API_KEY="[PLACEHOLDER]"
PUBLIC_FIREBASE_AUTH_DOMAIN="[PLACEHOLDER].firebaseapp.com"
PUBLIC_FIREBASE_PROJECT_ID="[PLACEHOLDER]"
PUBLIC_FIREBASE_STORAGE_BUCKET="[PLACEHOLDER].appspot.com"
PUBLIC_FIREBASE_MESSAGING_SENDER_ID="[PLACEHOLDER]"
PUBLIC_FIREBASE_APP_ID="[PLACEHOLDER]"

# Optional: set to "1" to log waitlist writes to the console in dev.
PUBLIC_WAITLIST_DEBUG="0"
